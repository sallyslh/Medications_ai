# ─── Django Core ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=medai_db
DB_USER=medai_user
DB_PASSWORD=pass
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# ─── CORS (comma-separated list of allowed React dev origins) ─────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ─── JWT Token Lifetimes ──────────────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME_MINUTES=60
# REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Production HTTPS enforcement (only relevant when DEBUG=False) ────────────
# Leave unset (defaults to True) once a real domain + TLS cert are in front of
# this app. Set to False only for a plain-HTTP deployment (e.g. bare IP, no
# cert) — otherwise Django redirect-loops every request to a nonexistent
# HTTPS listener.
# SECURE_SSL_REDIRECT=True
